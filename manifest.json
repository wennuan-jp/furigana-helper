{
  "manifest_version": 3,
  "name": "Furigana Helper",
  "version": "1.0.0",
  "description": "Easily view furigana or kanji candidates right above your selected text.",
  "icons": {
    "16": "furigana-helper-icon-16.png",
    "48": "furigana-helper-icon-48.png",
    "128": "furigana-helper-icon-128.png"
  },
  "action": {
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"]
    }
  ],
  "permissions": [
    "storage",
    "offscreen"
  ]
}
